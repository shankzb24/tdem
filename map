function renderCards(fk){
  const g=document.getElementById('g');
  g.innerHTML='';
  P.forEach(p=>{
    const rel=fk==='all'||(FK[fk]!==undefined&&p.journey[FK[fk]]===1);
    if(!rel)return;
    const c=document.createElement('div');
    c.className='card '+p.tier;
    c.setAttribute('data-id',p.id);
    c.onclick=()=>showDet(p.id);
    const dots=p.journey.map((o,i)=>`<span class="js${o?' on':''}">${SL[i]}</span>`).join('');
    const bs=p.badges.map(b=>`<span class="b ${b}">${b.replace('b','').toUpperCase()}</span>`).join('');
    c.innerHTML=`<p class="cn">${p.name}</p><p class="ct">${p.title}</p><div class="badges" style="margin-bottom:6px">${bs}</div><div class="jbar">${dots}</div>`;
    g.appendChild(c);
  });
}

function showDet(id){
  const p=P.find(x=>x.id===id);
  if(!p)return;
  document.querySelectorAll('.card').forEach(c=>c.classList.remove('on'));
  const el=document.querySelector('[data-id="'+id+'"]');
  if(el)el.classList.add('on');
  const d=document.getElementById('d');
  d.style.display='block';
  const dots=p.journey.map((o,i)=>`<span class="js${o?' on':''}">${SL[i]}</span>`).join('');
  d.innerHTML=`
    <p class="dn">${p.name}</p>
    <p class="dr">${p.title}</p>
    <div class="drow"><span class="dl">Email</span><span class="dv em">${p.email}</span></div>
    <div class="drow"><span class="dl">Organization</span><span class="dv">${p.org}</span></div>
    <div class="drow"><span class="dl">Connected to</span><span class="dv">${p.knows}</span></div>
    <div class="drow"><span class="dl">What they care about</span><span class="dv">${p.cares}</span></div>
    <div class="drow"><span class="dl">Power</span><span class="dv">${p.power}</span></div>
    <div class="drow"><span class="dl">Journey relevance</span><span class="dv"><div class="jbar" style="margin-top:2px">${dots}</div></span></div>
    <div class="drow"><span class="dl">Gaps / action needed</span><span class="dv gap">${p.gap}</span></div>
    <div class="drow"><span class="dl">Key note</span><span class="dv note">${p.note}</span></div>
  `;
}

function filt(k,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  renderCards(k);
  document.getElementById('d').style.display='none';
}
renderCards('all');
